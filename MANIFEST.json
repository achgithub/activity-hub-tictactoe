{
  "id": "tictactoe",
  "name": "Tic Tac Toe",
  "description": "Classic 3x3 grid game. Get three in a row to win!",
  "icon": "⭕",
  "type": "iframe",
  "category": "games",
  "tags": ["multiplayer", "strategy", "turn-based"],
  "min_players": 2,
  "max_players": 2,
  "is_active": true,
  "requires_auth": true,
  "binary_path": "~/activity-hub-tictactoe/backend/tictactoe-backend",
  "static_path": "~/activity-hub-tictactoe/frontend/build",
  "options_schema": {
    "firstTo": {
      "type": "select",
      "label": "First to",
      "description": "Win this many rounds to win the match",
      "options": [
        { "value": 1, "label": "1 round" },
        { "value": 2, "label": "Best of 3" },
        { "value": 3, "label": "Best of 5" }
      ],
      "default": 1
    }
  }
}
