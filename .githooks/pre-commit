#!/bin/bash

# Pre-commit hook for Activity Hub
# Enforces CSS standards and prevents styling drift
# All UI must use frontend/src/styles/activity-hub.css and .ah-* classes

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "рџ”Ќ Running Activity Hub CSS enforcement checks..."

ERRORS=0
WARNINGS=0

# ===================================================================
# CHECK 1: Block component-specific CSS files (zero tolerance)
# ===================================================================
echo ""
echo "Checking for component-specific CSS files..."

COMPONENT_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'frontend/src/components/.*\.css$' || true)
if [ ! -z "$COMPONENT_CSS" ]; then
    echo -e "${RED}вќЊ ERROR: Found component-specific CSS files (not allowed):${NC}"
    echo "$COMPONENT_CSS" | sed 's/^/  /'
    echo -e "${YELLOW}   Activity Hub enforces a single shared CSS file${NC}"
    echo -e "${YELLOW}   Import this in frontend/src/index.tsx:${NC}"
    echo "   import './styles/activity-hub.css';"
    echo -e "${YELLOW}   Use .ah-* classes for all styling${NC}"
    echo -e "${YELLOW}   See frontend/docs/CSS_GUIDE.md for available classes${NC}"
    ERRORS=$((ERRORS + 1))
fi

# ===================================================================
# CHECK 2: Verify @activity-hub/ui CSS import in frontend entry
# ===================================================================
echo ""
echo "Checking for Activity Hub CSS import in frontend..."

FRONTEND_INDEX="frontend/src/index.tsx"
if git diff --cached --name-only | grep -q "^$FRONTEND_INDEX$"; then
    if ! git diff --cached "$FRONTEND_INDEX" | grep -q "./styles/activity-hub.css"; then
        echo -e "${RED}вќЊ ERROR: $FRONTEND_INDEX must import Activity Hub CSS${NC}"
        echo -e "${YELLOW}   Add this import:${NC}"
        echo "   import './styles/activity-hub.css';"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}вњ“${NC} Activity Hub CSS import verified"
    fi
else
    # File not being modified, check if it exists and has the import
    if [ -f "$FRONTEND_INDEX" ]; then
        if ! grep -q "./styles/activity-hub.css" "$FRONTEND_INDEX"; then
            echo -e "${YELLOW}вљ пёЏ  WARNING: $FRONTEND_INDEX missing Activity Hub CSS import${NC}"
            echo -e "${YELLOW}   Add this import:${NC}"
            echo "   import './styles/activity-hub.css';"
            WARNINGS=$((WARNINGS + 1))
        else
            echo -e "${GREEN}вњ“${NC} Activity Hub CSS import found"
        fi
    fi
fi

# ===================================================================
# CHECK 3: Block all CSS imports except in index.tsx
# ===================================================================
echo ""
echo "Checking for CSS imports in component files..."

# Get all staged TypeScript files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(tsx?)$')

for FILE in $STAGED_FILES; do
    # Skip index.tsx files and shell entry points
    if [[ $FILE == *"index.tsx" ]] || [[ $FILE == *"index.ts" ]] || [[ $FILE == *"main.tsx" ]]; then
        continue
    fi

    # Check for CSS imports in component files
    CSS_IMPORTS=$(grep -n "import.*\.css" "$FILE" 2>/dev/null || true)
    if [ ! -z "$CSS_IMPORTS" ]; then
        echo -e "${RED}вќЊ ERROR: $FILE imports CSS directly${NC}"
        echo "$CSS_IMPORTS" | sed 's/^/  /'
        echo -e "${YELLOW}   Remove all CSS imports from component files${NC}"
        echo -e "${YELLOW}   Activity Hub CSS is loaded globally via index.tsx${NC}"
        echo -e "${YELLOW}   Use .ah-* classes for all styling${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# ===================================================================
# CHECK 4: Block inline styles (zero tolerance)
# ===================================================================
echo ""
echo "Checking for inline styles..."

for FILE in $STAGED_FILES; do
    # Check for style={{ patterns
    INLINE_STYLES=$(grep -n 'style={{' "$FILE" 2>/dev/null || true)
    if [ ! -z "$INLINE_STYLES" ]; then
        STYLE_COUNT=$(echo "$INLINE_STYLES" | wc -l | xargs)
        echo -e "${RED}вќЊ ERROR: $FILE has $STYLE_COUNT inline style declaration(s)${NC}"
        echo "$INLINE_STYLES" | head -5 | sed 's/^/  /'
        if [ "$STYLE_COUNT" -gt 5 ]; then
            echo "  ... (showing first 5 of $STYLE_COUNT)"
        fi
        echo -e "${YELLOW}   Use Activity Hub classes (.ah-*) instead of inline styles${NC}"
        echo -e "${YELLOW}   See frontend/docs/CSS_GUIDE.md for class reference${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# ===================================================================
# CHECK 5: Block hardcoded colors
# ===================================================================
echo ""
echo "Checking for hardcoded colors..."

for FILE in $STAGED_FILES; do
    # Look for hex colors (but allow #000 and #fff which are common in backgrounds)
    HEX_COLORS=$(grep -n '#[0-9a-fA-F]\{3,8\}' "$FILE" 2>/dev/null | grep -v '#000\|#fff\|#333\|#666' || true)
    if [ ! -z "$HEX_COLORS" ]; then
        echo -e "${YELLOW}вљ пёЏ  WARNING: $FILE contains hardcoded colors:${NC}"
        echo "$HEX_COLORS" | head -3 | sed 's/^/  /'
        echo -e "${YELLOW}   Activity Hub uses standardized colors (see frontend/docs/CSS_AUDIT.md)${NC}"
        echo -e "${YELLOW}   Use .ah-* classes with built-in color values${NC}"
        WARNINGS=$((WARNINGS + 1))
    fi
done

# ===================================================================
# CHECK 6: Verify TypeScript files (not .js)
# ===================================================================
echo ""
echo "Checking file extensions..."

JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'frontend/src/.*\.jsx?$' || true)
if [ ! -z "$JS_FILES" ]; then
    echo -e "${RED}вќЊ ERROR: Found .js/.jsx files in frontend/src:${NC}"
    echo "$JS_FILES" | sed 's/^/  /'
    echo -e "${YELLOW}   All React files must use TypeScript (.tsx)${NC}"
    ERRORS=$((ERRORS + 1))
fi

# ===================================================================
# CHECK 7: Warn about missing .ah-* classes in modified components
# ===================================================================
echo ""
echo "Checking for Activity Hub class usage..."

COMPONENT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'frontend/src/(components|pages)/.*\.tsx$' || true)

for FILE in $COMPONENT_FILES; do
    # Check if file has className attributes
    if grep -q 'className=' "$FILE"; then
        # Check if it uses .ah-* classes
        if ! grep -q 'className="[^"]*ah-' "$FILE" && ! grep -q "className='[^']*ah-" "$FILE"; then
            # Only warn if it's adding new content (not just whitespace changes)
            if git diff --cached "$FILE" | grep -q '^+.*className='; then
                echo -e "${YELLOW}вљ пёЏ  WARNING: $FILE may not be using Activity Hub classes${NC}"
                echo -e "${YELLOW}   Consider using .ah-* classes for consistent styling${NC}"
                echo -e "${YELLOW}   See frontend/docs/CSS_GUIDE.md for available classes${NC}"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    fi
done

# ===================================================================
# CHECK 8: Mini-apps must import activity-hub-sdk
# ===================================================================
echo ""
echo "Checking for SDK usage in mini-apps..."

# Detect if this is a mini-app by checking package.json for activity-hub-sdk
IS_MINI_APP=false
if [ -f "frontend/package.json" ] || [ -f "package.json" ]; then
    PACKAGE_JSON="package.json"
    [ -f "frontend/package.json" ] && PACKAGE_JSON="frontend/package.json"

    if grep -q '"activity-hub-sdk"' "$PACKAGE_JSON"; then
        IS_MINI_APP=true
    fi
fi

if [ "$IS_MINI_APP" = true ]; then
    echo "  рџ“¦ Mini-app detected - enforcing SDK component usage"

    # Check that components import AppHeader or GameCard
    COMPONENT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(tsx)$' || true)

    for FILE in $COMPONENT_FILES; do
        # Skip test files and config files
        if [[ $FILE == *".test."* ]] || [[ $FILE == *".spec."* ]] || [[ $FILE == *"config"* ]]; then
            continue
        fi

        # Check for manual ah-app-header usage (should use AppHeader component)
        MANUAL_HEADER=$(grep -n 'className="ah-app-header"' "$FILE" 2>/dev/null || true)
        if [ ! -z "$MANUAL_HEADER" ]; then
            echo -e "${RED}вќЊ ERROR: $FILE manually creates app header${NC}"
            echo "$MANUAL_HEADER" | sed 's/^/  /'
            echo -e "${YELLOW}   Use SDK component instead:${NC}"
            echo "   import { AppHeader } from 'activity-hub-sdk';"
            echo "   <AppHeader title=\"Your Title\" icon=\"рџЋ®\" />"
            ERRORS=$((ERRORS + 1))
        fi

        # Check for manual ah-lobby-btn in custom headers (should use AppHeader)
        MANUAL_LOBBY_BTN=$(grep -n 'className="ah-lobby-btn"' "$FILE" 2>/dev/null || true)
        if [ ! -z "$MANUAL_LOBBY_BTN" ]; then
            # Only error if it's part of a custom header structure
            if grep -q '<div className="ah-app-header' "$FILE"; then
                echo -e "${YELLOW}вљ пёЏ  WARNING: $FILE has manual header structure${NC}"
                echo -e "${YELLOW}   Consider using AppHeader component from SDK${NC}"
                echo "   import { AppHeader } from 'activity-hub-sdk';"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done

    # Check that SDK is imported where components are used
    for FILE in $COMPONENT_FILES; do
        # Skip if file doesn't use any ah- classes
        if ! grep -q 'ah-' "$FILE"; then
            continue
        fi

        # If file uses ah-app-header-related classes, ensure SDK is imported
        if grep -q 'ah-app-header\|ah-app-title' "$FILE"; then
            if ! grep -q "from 'activity-hub-sdk'" "$FILE" && ! grep -q 'from "activity-hub-sdk"' "$FILE"; then
                echo -e "${YELLOW}вљ пёЏ  WARNING: $FILE may need to import SDK components${NC}"
                echo -e "${YELLOW}   If using app headers, import from SDK:${NC}"
                echo "   import { AppHeader } from 'activity-hub-sdk';"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done
else
    echo "  в„№пёЏ  Not a mini-app - skipping SDK enforcement"
fi

# ===================================================================
# Summary
# ===================================================================
echo ""
echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}вќЊ Pre-commit check FAILED with $ERRORS error(s)${NC}"
    echo -e "${YELLOW}   Fix the errors above and try again${NC}"
    echo -e "${YELLOW}   To bypass hooks (not recommended): git commit --no-verify${NC}"
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}вљ пёЏ  Pre-commit check PASSED with $WARNINGS warning(s)${NC}"
    echo -e "${GREEN}   Warnings don't block commits, but consider addressing them${NC}"
    exit 0
else
    echo -e "${GREEN}вњ… All enforcement checks passed!${NC}"
    exit 0
fi
